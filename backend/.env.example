# ── Backend environment ─────────────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit the real .env (gitignored).

# Server
NODE_ENV=development
PORT=4000
# Comma-separated allowlist of frontend origins for CORS.
CORS_ORIGINS=http://localhost:5173

# Database (local Postgres). Adjust user/password to your setup.
# If you used docker-compose: postgres:postgres@localhost:5432
DATABASE_URL=postgresql://postgres@localhost:5432/spur_chat?schema=public

# Redis (optional — app degrades to in-memory if unreachable)
REDIS_URL=redis://localhost:6379

# ── OpenAI ──────────────────────────────────────────────────────────
# Required. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# LLM tuning / cost controls
LLM_MAX_OUTPUT_TOKENS=600
LLM_HISTORY_WINDOW=20
LLM_TIMEOUT_MS=30000

# Input + rate-limit guardrails
MAX_MESSAGE_LENGTH=4000
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX=20
